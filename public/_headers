/*
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff

# Solusi Sanitizer: Paksa semua file ttf dikirim dengan MIME type font yang bener
/*.ttf
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *

# Khusus handle path font dari node_modules expo vector icons
/assets/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/*
  Content-Type: font/ttf
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000
